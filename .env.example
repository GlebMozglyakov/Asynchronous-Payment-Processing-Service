APP_NAME=Asynchronous Payment Processing Service
APP_VERSION=0.1.0
ENVIRONMENT=local
DEBUG=false

API_HOST=0.0.0.0
API_PORT=8000
API_KEY=change-me-api-key

DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/payments

RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
PAYMENTS_EXCHANGE=payments.exchange
PAYMENTS_ROUTING_KEY=payments.new
PAYMENTS_QUEUE=payments.new
PAYMENTS_RETRY_EXCHANGE=payments.retry
PAYMENTS_RETRY_QUEUE=payments.new.retry
PAYMENTS_DLX_EXCHANGE=payments.dlx
PAYMENTS_DLQ=payments.new.dlq
ENABLE_BROKER_STARTUP=true
ENABLE_OUTBOX_RELAY=true
CONSUMER_RETRY_ATTEMPTS=3
CONSUMER_RETRY_BASE_DELAY_SECONDS=1

OUTBOX_POLL_INTERVAL_SECONDS=1
OUTBOX_BATCH_SIZE=100
OUTBOX_LOCK_TTL_SECONDS=60

WEBHOOK_TIMEOUT_SECONDS=3
WEBHOOK_RETRY_ATTEMPTS=3
WEBHOOK_RETRY_BASE_DELAY_SECONDS=1

GATEWAY_SLEEP_MIN_SECONDS=2
GATEWAY_SLEEP_MAX_SECONDS=5
GATEWAY_SUCCESS_RATE=0.9
